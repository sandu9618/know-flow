# MongoDB — local Docker Compose (default) or MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/knowflow
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/knowflow

# LLM provider (Week 2+) — provider-agnostic via LlmClient
LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key-here
# LLM_CHAT_MODEL=gemini-2.0-flash
# LLM_EMBEDDING_MODEL=text-embedding-004
# LLM_FALLBACK_MODEL=gemini-1.5-flash

# Node API
PORT=3000

# React (Vite) — exposed to browser
VITE_API_URL=http://localhost:3000

# Internal service URLs
PYTHON_WORKER_URL=http://localhost:8000

# Redis — BullMQ job queue (Week 9+)
REDIS_URL=redis://localhost:6379

# Cloud bucket — file-upload sources (Week 2+)
# BUCKET_PROVIDER=s3
# BUCKET_REGION=us-east-1
# BUCKET_NAME=knowflow-uploads
# BUCKET_ACCESS_KEY=
# BUCKET_SECRET_KEY=
